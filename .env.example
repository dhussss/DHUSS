# Runtime connection via Supabase shared transaction-mode pooler.
DATABASE_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct/session-mode connection used by Prisma migrations.
DIRECT_URL="postgresql://postgres.<PROJECT-REF>:<PASSWORD>@<REGION>.pooler.supabase.com:5432/postgres"

# Required in production to open /diagnostics.
DIAGNOSTICS_TOKEN="change-this-long-random-token"
# Existing deployments may keep using BACKUP_EXPORT_TOKEN as a legacy fallback.

# Canonical public product URL. Use the custom production domain here; previews
# use VERCEL_URL automatically and must not point back to production.
APP_BASE_URL="https://app.example.com"

# Public-safe central product identity. These values control browser metadata,
# authentication presentation, the PWA manifest, and platform attribution.
NEXT_PUBLIC_PRODUCT_NAME="Trade Invoice Tracker"
NEXT_PUBLIC_PRODUCT_SHORT_NAME="Trade Tracker"
NEXT_PUBLIC_PRODUCT_DESCRIPTION="Work, expense, team and invoice tracking for Australian trade businesses."
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

# Optional visible build label. Production defaults to "Approved Build" while
# local development and Vercel previews default to "Development Build".
# NEXT_PUBLIC_APP_VERSION="0.1.0"
# NEXT_PUBLIC_BUILD_CHANNEL="Approved Build"

# Optional one-step invoice email delivery with PDF attachment. SMTP credentials
# belong to the platform, not an individual tenant. INVOICE_FROM_EMAIL must be a
# verified platform address. Tenant email addresses are used only as Reply-To.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="smtp-account@example.com"
# SMTP_PASSWORD="<provider-secret>"
# INVOICE_FROM_EMAIL="invoices@example.com"
# SMTP_FROM_EMAIL="invoices@example.com" # Legacy fallback only.

# Real email/SMS delivery is blocked in local and preview builds by default.
# Enable only for a controlled provider test with safe recipients.
# ALLOW_NON_PRODUCTION_DELIVERY="false"

# Optional one-step invoice SMS/MMS delivery with PDF attachment.
# Twilio fetches the PDF from APP_BASE_URL/public/invoices/<token>/pdf.
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""
# TWILIO_MESSAGING_SERVICE_SID=""

# Optional future HTML/provider email delivery.
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL=""

# Supabase Auth/Storage browser-safe project settings.
NEXT_PUBLIC_SUPABASE_URL="https://<PROJECT-REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<SUPABASE-PUBLISHABLE-KEY>"

# Optional server-only key used to include private business logos on public
# invoice pages/PDFs. Never prefix this key with NEXT_PUBLIC_.
# SUPABASE_SECRET_KEY="<SUPABASE-SECRET-KEY>"

# The demo seed deletes application rows and is disabled unless this explicit
# local-development acknowledgement is present. Never set it in production.
# ALLOW_DESTRUCTIVE_SEED="false"
