generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum BillingStatus {
  UNBILLED
  BILLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum LineItemType {
  LABOUR
  EXPENSE
}

model Client {
  id           String    @id @default(cuid())
  ownerId      String?
  businessName String
  contactName  String?
  email        String?
  phone        String?
  abn          String?
  address      String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  projects     Project[]
  invoices     Invoice[]

  @@index([businessName])
  @@index([updatedAt])
  @@index([ownerId])
  @@index([ownerId, businessName])
}

model Project {
  id                      String        @id @default(cuid())
  ownerId                 String?
  title                   String
  clientId                String
  currentHourlyRateCents  Int
  status                  ProjectStatus @default(ACTIVE)
  notes                   String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  client                  Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  timeEntries             TimeEntry[]
  expenseItems            ExpenseItem[]
  invoices                Invoice[]
  rateHistory             RateHistory[]

  @@index([clientId])
  @@index([status])
  @@index([updatedAt])
  @@index([ownerId])
  @@index([ownerId, clientId])
  @@index([ownerId, status])
}

model RateHistory {
  id        String   @id @default(cuid())
  ownerId   String?
  projectId String
  rateCents Int
  startsAt  DateTime @default(now())
  notes     String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, startsAt])
  @@index([ownerId, projectId])
}

model TimeEntry {
  id                       String        @id @default(cuid())
  ownerId                  String?
  projectId                String
  invoiceId                String?
  date                     DateTime
  startTime                String?
  endTime                  String?
  durationMinutes          Int
  notes                    String?
  billingStatus            BillingStatus @default(UNBILLED)
  hourlyRateCentsSnapshot  Int
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  project                  Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  invoice                  Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceLineItems         InvoiceLineItem[]

  @@index([projectId, date])
  @@index([billingStatus])
  @@index([invoiceId])
  @@index([date])
  @@index([updatedAt])
  @@index([ownerId, projectId])
  @@index([ownerId, date])
  @@index([ownerId, billingStatus])
  @@index([ownerId, invoiceId])
}

model ExpenseItem {
  id              String        @id @default(cuid())
  ownerId         String?
  projectId       String
  invoiceId       String?
  datePurchased   DateTime
  description     String
  quantity        Decimal       @default(1)
  unitCostCents   Int
  totalCostCents  Int
  notes           String?
  billingStatus   BillingStatus @default(UNBILLED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Restrict)
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceLineItems InvoiceLineItem[]

  @@index([projectId, datePurchased])
  @@index([billingStatus])
  @@index([invoiceId])
  @@index([datePurchased])
  @@index([updatedAt])
  @@index([ownerId, projectId])
  @@index([ownerId, datePurchased])
  @@index([ownerId, billingStatus])
  @@index([ownerId, invoiceId])
}

model Invoice {
  id             String            @id @default(cuid())
  ownerId        String?
  invoiceNumber  String
  projectId      String
  clientId       String
  invoiceDate    DateTime
  dateRangeStart DateTime
  dateRangeEnd   DateTime
  status         InvoiceStatus     @default(DRAFT)
  totalHours     Decimal           @default(0)
  labourTotalCents Int             @default(0)
  itemTotalCents   Int             @default(0)
  grandTotalCents  Int             @default(0)
  paymentDate    DateTime?
  summary        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  client         Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  timeEntries    TimeEntry[]
  expenseItems   ExpenseItem[]
  lineItems      InvoiceLineItem[]

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([invoiceDate])
  @@index([paymentDate])
  @@index([updatedAt])
  @@index([ownerId, projectId])
  @@index([ownerId, clientId])
  @@index([ownerId, status])
  @@index([ownerId, invoiceDate])
  @@unique([ownerId, invoiceNumber])
}

model InvoiceLineItem {
  id                String       @id @default(cuid())
  ownerId           String?
  invoiceId         String
  timeEntryId       String?
  expenseItemId     String?
  type              LineItemType
  description       String
  date              DateTime?
  quantity          Decimal?
  hoursMinutes      Int?
  unitAmountCents   Int
  totalAmountCents  Int
  notes             String?
  sortOrder         Int          @default(0)
  invoice           Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  timeEntry         TimeEntry?   @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  expenseItem       ExpenseItem? @relation(fields: [expenseItemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([timeEntryId])
  @@index([expenseItemId])
  @@index([ownerId, invoiceId])
}

model BusinessProfile {
  id                         String   @id @default(cuid())
  ownerId                    String   @unique
  tradingName                String
  legalName                  String?
  abn                        String?
  acn                        String?
  contactName                String?
  email                      String?
  phone                      String?
  address                    String?
  website                    String?
  defaultHourlyRateCents     Int?
  gstRegistered              Boolean  @default(false)
  gstRate                    Decimal  @default(10)
  bankAccountName            String?
  bsb                        String?
  accountNumber              String?
  paymentTermsDays           Int      @default(14)
  defaultInvoiceNotes        String?
  defaultInvoiceEmailMessage String?
  logoPath                   String?
  signatureFooter            String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([ownerId])
}
